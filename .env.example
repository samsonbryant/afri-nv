# =============================================================================
# Novixa - AI Business Operating System
# Environment Variables (copy to .env and fill in values)
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
DJANGO_ENV=development
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,api.novixa.local
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Novixa
NEXT_PUBLIC_APP_DESCRIPTION=AI Business Operating System

# -----------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=novixa
POSTGRES_USER=novixa
POSTGRES_PASSWORD=novixa_dev_password
DATABASE_URL=postgresql://novixa:novixa_dev_password@localhost:5432/novixa

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CACHE_URL=redis://localhost:6379/3

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_SIGNING_KEY=change-me-jwt-signing-key

# -----------------------------------------------------------------------------
# AI / LLM Providers
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# Leave empty for api.openai.com. For OpenRouter keys (sk-or-*) set:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
AI_DEFAULT_PROVIDER=openai
# Prefer mini for cost; OpenRouter auto-prefixes openai/ for bare ids
AI_DEFAULT_MODEL=gpt-4o-mini
# OpenRouter reserves max_tokens against credits — keep modest on free/low balance
AI_MAX_TOKENS=1024
# Free plan orgs: max AI chats/completions per calendar month
FREE_AI_REQUEST_LIMIT=5
FREE_AI_MAX_TOKENS=180
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# -----------------------------------------------------------------------------
# Email (optional in development)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@novixa.ai

# -----------------------------------------------------------------------------
# Storage (S3-compatible — optional in development)
# -----------------------------------------------------------------------------
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=novixa
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Render / Production
# -----------------------------------------------------------------------------
RENDER=False
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120
