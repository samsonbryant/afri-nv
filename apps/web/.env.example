# =============================================================================
# Novixa Web — Frontend Environment Variables
# Copy to .env.local and adjust as needed
# =============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
# Local: point straight at Django. Production (Vercel): use /api/v1 + API_PROXY_TARGET
# so browsers never call Render directly (required for Orange Liberia connectivity).
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# Server-only on Vercel — origin of the Django API for Next.js rewrites:
# API_PROXY_TARGET=https://novixa-api.onrender.com
# Optional: force same-origin proxy even when NEXT_PUBLIC_API_URL is absolute
# NEXT_PUBLIC_USE_API_PROXY=true
NEXT_PUBLIC_APP_NAME=Novixa
NEXT_PUBLIC_APP_DESCRIPTION=AI Business Operating System
# Use frontend demo fixtures instead of the API (keep false for local API testing)
NEXT_PUBLIC_DEMO_MODE=false
